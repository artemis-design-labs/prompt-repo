# Neon Postgres Database Connection
# Get this from your Neon dashboard after creating a database via Vercel Storage
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Anthropic Claude API (for AI Chat feature)
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email delivery for verification + password reset (Resend)
# Get an API key from https://resend.com/. If unset, email links are logged
# to the server console instead of being sent (fine for local development).
RESEND_API_KEY=your_resend_api_key_here
# Verified sender. Defaults to Resend's onboarding@resend.dev test sender.
EMAIL_FROM="Prompt Repository <onboarding@resend.dev>"

# Base URL used to build verification / reset links in emails.
# Local: http://localhost:3000  Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
